{
	"name": "frontend",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"openapi-ts": "curl http://localhost:8080/docs > openapi.json && openapi-ts",
		"android-dev": "concurrently \"bun run dev --host\" \"bunx cap sync android\" \"bunx cap open android\"",
		"ios-dev": "bunx cap sync ios && concurrently \"bun run dev --host\" \"bunx cap open ios\""
	},
	"devDependencies": {
		"@capacitor/cli": "^8.2.0",
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "^9.39.2",
		"@hey-api/openapi-ts": "0.93.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.1.18",
		"@types/node": "^22",
		"concurrently": "^9.2.1",
		"daisyui": "^5.5.19",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.14.0",
		"eslint-plugin-unused-imports": "^4.4.1",
		"globals": "^17.3.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.51.0",
		"svelte-check": "^4.3.6",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.54.0",
		"vite": "^7.3.1",
		"vite-plugin-devtools-json": "^1.0.0"
	},
	"dependencies": {
		"@capacitor/android": "^8.2.0",
		"@capacitor/assets": "^3.0.5",
		"@capacitor/clipboard": "^8.0.1",
		"@capacitor/core": "^8.2.0",
		"@capacitor/ios": "^8.2.0",
		"@capacitor/keyboard": "^8.0.1",
		"@capacitor/preferences": "^8.0.1",
		"@capacitor/screen-orientation": "^8.0.1",
		"@lucide/svelte": "^0.577.0",
		"chart.js": "^4.5.1",
		"frontend": ".",
		"svelte-chartjs": "^4.0.1",
		"svelte-confetti": "^2.3.2"
	}
}
